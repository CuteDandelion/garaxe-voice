# Local PGlite is used when DATABASE_URL is absent.
DATABASE_URL=postgresql://user:password@host:5432/garaxe?sslmode=require
GARAXE_ALLOWED_ORIGIN=https://voice.example.com
GARAXE_MAX_BODY_BYTES=5242880
NODE_ENV=production

# Google OAuth credentials belong in a managed secret store. Never commit values.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://voice.example.com/api/connections/google/callback
GARAXE_OAUTH_ENVELOPE_KEY=
# OpenCode Go — server-side only. Never expose this through Vite/client variables.
OPENCODE_GO_API_KEY=
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_GO_DEFAULT_MODEL=qwen3.7-plus
OPENCODE_GO_ESCALATION_MODEL=qwen3.7-plus
OPENCODE_GO_TIMEOUT_MS=180000

# Optional root-cause-first cluster interpretation. Rate and concurrency limits are always required.
GARAXE_LLM_ENRICHMENT_ENABLED=true
# Leave spend enforcement off for capacity-priced providers such as OpenCode Go. Turn it on only
# when the provider has a verified monetary pricing contract and all integer-micro limits below apply.
GARAXE_LLM_BUDGET_ENFORCED=false
GARAXE_LLM_GLOBAL_BUDGET_MICRO=5000000
GARAXE_LLM_ORGANIZATION_BUDGET_MICRO=1000000
GARAXE_LLM_PROJECT_BUDGET_MICRO=500000
GARAXE_LLM_RUN_BUDGET_MICRO=100000
GARAXE_LLM_RESERVATION_MICRO=100000
GARAXE_LLM_REQUEST_CAPACITY=2
GARAXE_LLM_REQUESTS_PER_SECOND=0.2
GARAXE_LLM_TOKEN_CAPACITY=16000
GARAXE_LLM_TOKENS_PER_SECOND=500
GARAXE_LLM_GLOBAL_CONCURRENCY=2
GARAXE_LLM_PROVIDER_CONCURRENCY=2
GARAXE_LLM_ORGANIZATION_CONCURRENCY=2
GARAXE_LLM_MAX_OUTPUT_TOKENS=1800
GARAXE_LLM_DEADLINE_MS=240000
